# Copy this file to something like deploy.env and pass it with:
#   sudo bash scripts/install.sh --env-file deploy.env

# pause: stop and wait for Enter at manual checkpoints
# exit: stop immediately at manual checkpoints so the next run resumes from there
MODE='pause'

# raw: deploy zrok with docker compose on the host
# dokploy-compose-api: experimental Dokploy-managed Docker Compose deployment
DEPLOY_METHOD='raw'

DOKPLOY_DOMAIN='dokploy.example.com'
DOKPLOY_URL='https://dokploy.example.com'
# Fill this in after creating the first Dokploy admin and API token.
DOKPLOY_API_TOKEN=''

ZROK_DOMAIN='zrok.example.com'
ZROK_INSTANCE_DIR='/opt/zrok-instance'
TRAEFIK_CERT_RESOLVER='letsencrypt'

ZROK_CTRL_PORT='18080'
ZROK_FRONTEND_INTERNAL_PORT='8080'
ZROK_PUBLIC_HTTPS_PORT='443'
ZROK_OAUTH_PORT='8081'
ZITI_CTRL_ADVERTISED_PORT='1443'
ZITI_ROUTER_PORT='3022'

# The script auto-generates these if they are blank.
ZROK_ADMIN_TOKEN=''
ZITI_PWD=''

# Fill these in before or during the zrok account creation step.
ZROK_USER_EMAIL='admin@example.com'
ZROK_USER_PWD=''

# Optional: set this after the first successful zrok account creation.
ZROK_ACCOUNT_TOKEN=''

# Optional Dokploy installer controls.
DOKPLOY_VERSION='latest'
# ADVERTISE_ADDR='203.0.113.10'
# DOCKER_SWARM_INIT_ARGS='--default-addr-pool 172.20.0.0/16 --default-addr-pool-mask-length 24'

# Set to false if you do not want npm/@dokploy/cli used.
# If true, the installer now requires an existing Node.js 18+ + npm installation.
INSTALL_DOKPLOY_CLI='true'

# Optional values used when DEPLOY_METHOD='dokploy-compose-api'.
DOKPLOY_PROJECT_NAME='zrok'
DOKPLOY_PROJECT_DESCRIPTION='Self-hosted zrok services'
DOKPLOY_ENVIRONMENT_NAME='production'
DOKPLOY_ENVIRONMENT_DESCRIPTION='Production services'
DOKPLOY_COMPOSE_NAME='zrok-instance'
DOKPLOY_COMPOSE_DESCRIPTION='Self-hosted zrok on Dokploy'
DOKPLOY_COMPOSE_APP_NAME='zrok-instance'
# DOKPLOY_PROJECT_ID=''
# DOKPLOY_ENVIRONMENT_ID=''
# DOKPLOY_COMPOSE_ID=''
